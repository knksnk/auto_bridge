generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  SELLER
  CARRIER
}

enum CarStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadType {
  CAR
  PARTNER
  GENERAL
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CLOSED
}

enum PartnerApplicationType {
  SELLER
  CARRIER
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  passwordHash String
  name         String
  phone        String?
  city         String?
  role         Role          @default(USER)
  favorites    Favorite[]
  compareItems CompareItem[]
  leads        Lead[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Seller {
  id        String   @id @default(cuid())
  name      String
  city      String
  rating    Float    @default(4.8)
  verified  Boolean  @default(true)
  phone     String?
  email     String?
  cars      Car[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Car {
  id             String        @id @default(cuid())
  slug           String        @unique
  title          String
  brand          String
  model          String
  year           Int
  mileageKm      Int
  trim           String
  color          String
  engine         String
  power          String
  fuel           String
  body           String
  doors          Int
  drive          String
  transmission   String
  chinaPrice     Int
  turnkeyPrice   Int
  logisticsPrice Int
  deliveryTime   String
  route          String
  inspection     String
  coverTone      String        @default("blue")
  tags           String[]
  isVerified     Boolean       @default(true)
  status         CarStatus     @default(DRAFT)
  sellerId       String
  seller         Seller        @relation(fields: [sellerId], references: [id])
  images         CarImage[]
  favorites      Favorite[]
  compareItems   CompareItem[]
  leads          Lead[]
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([brand])
  @@index([model])
  @@index([status])
  @@index([turnkeyPrice])
  @@index([year])
}

model CarImage {
  id        String   @id @default(cuid())
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  url       String
  alt       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([carId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, carId])
}

model CompareItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  carId     String
  car       Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, carId])
}

model Lead {
  id        String     @id @default(cuid())
  type      LeadType   @default(CAR)
  status    LeadStatus @default(NEW)
  name      String
  phone     String
  email     String?
  comment   String?
  carId     String?
  car       Car?       @relation(fields: [carId], references: [id], onDelete: SetNull)
  userId    String?
  user      User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model PartnerApplication {
  id        String                 @id @default(cuid())
  type      PartnerApplicationType
  name      String
  company   String
  phone     String
  email     String
  city      String
  comment   String?
  status    LeadStatus             @default(NEW)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}

model DealRequest {
  id        String     @id @default(cuid())
  status    LeadStatus @default(NEW)
  carId     String?
  userId    String?
  payload   Json
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}
